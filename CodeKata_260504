#include <string>
#include <vector>

using namespace std;

int solution(int n) {
    int answer = 0;

    // n이 0보다 큰 동안 반복합니다.
    while (n > 0) {
        // n을 2로 나눈 나머지가 0이라면 (짝수라면)
        if (n % 2 == 0) {
            answer += n; // answer = answer + n; 과 같습니다.
        }
        
        // 짝수든 홀수든 상관없이 다음 숫자를 확인하기 위해 1을 줄입니다.
        n--; 
    }

    return answer;
}
