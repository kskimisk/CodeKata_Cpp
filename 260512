#include <string>
#include <vector>
#include <cassert>

using namespace std;

int solution(int n) {
    assert(3 <= n && n <= 1000000);
    
    int answer = 0;
        
    for(int x = 2; x < n; x++)
    {
        if(n % x == 1)
        {
            answer = x;
            break;
        }
        
    }
    return answer;
}
