#include <string>
#include <vector>
#include <iostream>
#include <cassert>

using namespace std;

int solution(int n) {
    assert(0<=n && n<=3000);
    int answer = 0;
    vector<int> divisors;
    
    for(int i = 1; i <= n; i++) {
        if(n % i == 0){
            answer += i;
            divisors.push_back(i);
        }
    }
    
    if (n > 0) {
        cout << n << "의 약수는 ";
        
        for(int i = 0; i < divisors.size(); i++) {
            cout << divisors[i];
            
            if(i != divisors.size() - 1) {
                cout << ", ";
            }
        }
        cout << "입니다. 이를 모두 더하면 " << answer << "입니다. \n";

    }
    
        
    return answer;
}
